GEMINI_API_KEY=your_google_ai_studio_key_here

# Gemini Models (per-agent configurable)
# Available: gemini-2.5-flash-lite, gemini-2.0-flash-lite, gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite
GEMINI_RESEARCHER_MODEL=gemini-2.5-flash-lite
GEMINI_EDITOR_MODEL=gemini-2.5-flash-lite
